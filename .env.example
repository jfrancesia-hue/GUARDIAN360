# Entorno
NODE_ENV=development
APP_NAME=Guardián360
FRONTEND_URL=http://localhost:3000
API_PORT=3001

# PostgreSQL / PostGIS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=guardian360
DB_USER=guardian
DB_PASSWORD=change_me_local
DATABASE_URL=postgresql://guardian:change_me_local@localhost:5432/guardian360

# Redis / BullMQ
REDIS_PASSWORD=change_me_redis
REDIS_URL=redis://:change_me_redis@localhost:6379

# Auth
JWT_SECRET=change_me_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Object storage MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=guardian
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=guardian360-dev

# MQTT
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=guardian
MQTT_PASSWORD=change_me_mqtt

# Observabilidad
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_PASSWORD=change_me_grafana

# Mapas e integraciones
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_TOKEN=
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
FCM_PROJECT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# IA
VISION_AI_PORT=8001
SATELLITE_PATROL_PORT=8002
MODEL_STORAGE_PATH=/app/models_weights
